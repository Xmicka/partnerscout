# GEMINI_API_KEY: Required for service API calls.
# Set this value in a local .env file. Do not commit your real API key.
GEMINI_API_KEY=""

# APP_URL: The app URL for local or deployed hosting.
# Used for self-referential links and API callbacks.
APP_URL="http://localhost:5173"

# SERPER_API_KEY: Optional. Target API key for Serper.dev Google Search.
# If not provided, the application will fall back to its built-in web query behavior.
SERPER_API_KEY=""
